{
    "name": "grails-extension-vscode",
    "displayName": "Grails Support For VS Code",
    "description": "Grails language support for VS Code — navigation, completion, project tree, CLI",
    "version": "0.4.0",
    "publisher": "JohanMixtegaCisneros",
    "repository": {
        "type": "git",
        "url": "https://github.com/Johan070119/Grails-VsCode-Extension"
    },
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Programming Languages",
        "Other"
    ],
    "keywords": [
        "grails",
        "groovy",
        "gsp",
        "java",
        "spring",
        "mvc",
        "web framework",
        "language server",
        "lsp",
        "autocomplete",
        "navigation",
        "scaffold",
        "domain",
        "controller",
        "service"
    ],
    "activationEvents": [
        "onLanguage:groovy",
        "workspaceContains:grails-app"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "groovy",
                "extensions": [
                    ".groovy",
                    ".gsp"
                ],
                "aliases": [
                    "Groovy",
                    "Grails"
                ]
            }
        ],
        "configuration": {
            "title": "Grails",
            "properties": {
                "grails.trace.server": {
                    "type": "string",
                    "enum": [
                        "off",
                        "messages",
                        "verbose"
                    ],
                    "default": "off",
                    "description": "Trace LSP communication"
                }
            }
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "grails-explorer",
                    "title": "Grails Project",
                    "icon": "images/grails-icon.svg"
                }
            ]
        },
        "views": {
            "grails-explorer": [
                {
                    "id": "grailsProjectExplorer",
                    "name": "Project Structure"
                }
            ]
        },
        "commands": [
            {
                "command": "grails.runApp",
                "title": "Correr Aplicación",
                "category": "Grails",
                "icon": "$(play)"
            },
            {
                "command": "grails.stopApp",
                "title": "Detener",
                "category": "Grails",
                "icon": "$(debug-stop)"
            },
            {
                "command": "grails.clean",
                "title": "Limpiar",
                "category": "Grails",
                "icon": "$(trash)"
            },
            {
                "command": "grails.compile",
                "title": "Compilar",
                "category": "Grails",
                "icon": "$(tools)"
            },
            {
                "command": "grails.refreshTree",
                "title": "Refrescar",
                "category": "Grails",
                "icon": "$(refresh)"
            },
            {
                "command": "grails.ctx.createController",
                "title": "Nuevo Controller",
                "category": "Grails"
            },
            {
                "command": "grails.ctx.createDomain",
                "title": "Nuevo Domain Class",
                "category": "Grails"
            },
            {
                "command": "grails.ctx.createService",
                "title": "Nuevo Service",
                "category": "Grails"
            },
            {
                "command": "grails.ctx.createView",
                "title": "Nueva Vista (GSP)",
                "category": "Grails"
            },
            {
                "command": "grails.ctx.createTagLib",
                "title": "Nuevo TagLib",
                "category": "Grails"
            },
            {
                "command": "grails.runAppDebug",
                "title": "Correr Aplicación (Debug)",
                "category": "Grails"
            },
            {
                "command": "grails.testApp",
                "title": "Ejecutar Tests",
                "category": "Grails"
            },
            {
                "command": "grails.ctx.createFolder",
                "title": "Nueva Carpeta",
                "category": "Grails"
            },
            {
                "command": "grails.ctx.createFile",
                "title": "Nuevo Archivo",
                "category": "Grails"
            },
            {
                "command": "grails.ctx.rename",
                "title": "Renombrar",
                "category": "Grails"
            },
            {
                "command": "grails.ctx.delete",
                "title": "Eliminar",
                "category": "Grails"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "grails.runApp",
                    "when": "view == grailsProjectExplorer",
                    "group": "navigation@1"
                },
                {
                    "command": "grails.stopApp",
                    "when": "view == grailsProjectExplorer",
                    "group": "navigation@2"
                },
                {
                    "command": "grails.clean",
                    "when": "view == grailsProjectExplorer",
                    "group": "navigation@3"
                },
                {
                    "command": "grails.compile",
                    "when": "view == grailsProjectExplorer",
                    "group": "navigation@4"
                },
                {
                    "command": "grails.refreshTree",
                    "when": "view == grailsProjectExplorer",
                    "group": "navigation@5"
                }
            ],
            "commandPalette": [
                {
                    "command": "grails.runApp",
                    "when": "false"
                },
                {
                    "command": "grails.stopApp",
                    "when": "false"
                },
                {
                    "command": "grails.clean",
                    "when": "false"
                },
                {
                    "command": "grails.compile",
                    "when": "false"
                },
                {
                    "command": "grails.refreshTree",
                    "when": "false"
                },
                {
                    "command": "grails.ctx.createController",
                    "when": "false"
                },
                {
                    "command": "grails.ctx.createDomain",
                    "when": "false"
                },
                {
                    "command": "grails.ctx.createService",
                    "when": "false"
                },
                {
                    "command": "grails.ctx.createView",
                    "when": "false"
                },
                {
                    "command": "grails.ctx.createTagLib",
                    "when": "false"
                },
                {
                    "command": "grails.runAppDebug",
                    "when": "workspaceContains:grails-app"
                },
                {
                    "command": "grails.testApp",
                    "when": "workspaceContains:grails-app"
                },
                {
                    "command": "grails.ctx.createFolder",
                    "when": "false"
                },
                {
                    "command": "grails.ctx.createFile",
                    "when": "false"
                },
                {
                    "command": "grails.ctx.rename",
                    "when": "false"
                },
                {
                    "command": "grails.ctx.delete",
                    "when": "false"
                }
            ],
            "view/item/context": [
                {
                    "command": "grails.ctx.createController",
                    "when": "view == grailsProjectExplorer && viewItem == grailsFolder_controllers",
                    "group": "1_create@1"
                },
                {
                    "command": "grails.ctx.createDomain",
                    "when": "view == grailsProjectExplorer && viewItem == grailsFolder_domain",
                    "group": "1_create@1"
                },
                {
                    "command": "grails.ctx.createService",
                    "when": "view == grailsProjectExplorer && viewItem == grailsFolder_services",
                    "group": "1_create@1"
                },
                {
                    "command": "grails.ctx.createView",
                    "when": "view == grailsProjectExplorer && viewItem == grailsFolder_views",
                    "group": "1_create@1"
                },
                {
                    "command": "grails.ctx.createTagLib",
                    "when": "view == grailsProjectExplorer && viewItem == grailsFolder_taglib",
                    "group": "1_create@1"
                },
                {
                    "command": "grails.ctx.createFolder",
                    "when": "view == grailsProjectExplorer && viewItem =~ /^grailsFolder/",
                    "group": "2_generic@1"
                },
                {
                    "command": "grails.ctx.createFile",
                    "when": "view == grailsProjectExplorer && viewItem =~ /^grailsFolder/",
                    "group": "2_generic@2"
                },
                {
                    "command": "grails.ctx.createController",
                    "when": "view == grailsProjectExplorer && viewItem == grailsFolder",
                    "group": "3_grails@1"
                },
                {
                    "command": "grails.ctx.createDomain",
                    "when": "view == grailsProjectExplorer && viewItem == grailsFolder",
                    "group": "3_grails@2"
                },
                {
                    "command": "grails.ctx.createService",
                    "when": "view == grailsProjectExplorer && viewItem == grailsFolder",
                    "group": "3_grails@3"
                },
                {
                    "command": "grails.ctx.createView",
                    "when": "view == grailsProjectExplorer && viewItem == grailsFolder",
                    "group": "3_grails@4"
                },
                {
                    "command": "grails.ctx.rename",
                    "when": "view == grailsProjectExplorer && viewItem =~ /^grailsFolder|^grailsFile/",
                    "group": "9_manage@1"
                },
                {
                    "command": "grails.ctx.delete",
                    "when": "view == grailsProjectExplorer && viewItem =~ /^grailsFolder|^grailsFile/",
                    "group": "9_manage@2"
                }
            ]
        }
    },
    "scripts": {
        "compile": "tsc -p tsconfig.json && npm run compile:server",
        "compile:server": "cd server && tsc -p tsconfig.json",
        "watch": "tsc -p tsconfig.json --watch",
        "watch:server": "cd server && tsc -p tsconfig.json --watch",
        "build": "npm run compile",
        "vscode:prepublish": "npm run build"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.0"
    },
    "devDependencies": {
        "@types/node": "^25.4.0",
        "@types/vscode": "^1.80.0",
        "typescript": "^5.9.3"
    },
    "icon": "images/icon.png"
}
